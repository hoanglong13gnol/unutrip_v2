# =========================
# UnuTrip root environment
# Used by:
# - backend/nodejs
# - backend/rag
# Android app does NOT read this file (see ../local.properties instead).
# =========================


# =========================
# Node.js backend
# =========================
NODE_ENV=development

BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000

JWT_SECRET=your_jwt_secret_key_here


# =========================
# MySQL / MariaDB
# =========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=unudata

# mysql2 pool connectionLimit (default 10)
# DB_POOL_CONNECTION_LIMIT=10

# Behind reverse proxy (nginx, LB): trust X-Forwarded-* for req.ip
# TRUST_PROXY=true


# =========================
# RAG / AI service
# =========================
RAG_HOST=127.0.0.1
RAG_PORT=8001
RAG_BASE_URL=http://127.0.0.1:8001

# Node → RAG HTTP client (backend/nodejs)
# RAG_FETCH_TIMEOUT_MS=90000
# RAG_FETCH_MAX_ATTEMPTS=3
# AI_MODEL_FETCH_TIMEOUT_MS=120000
# Timeout admin /admin/rag-ai/debug-query → FastAPI (mặc định 120s; pipeline + Gemini có thể lâu)
# RAG_ADMIN_DEBUG_TIMEOUT_MS=120000
# Bỏ qua probe RAG trong GET /api/health/ready (RAG tùy chọn trong môi trường)
# HEALTHCHECK_SKIP_RAG=false

AI_RUNTIME_MODE=demo
ENABLE_GEMINI=true
ENABLE_LORA=false
ENABLE_VALIDATOR=false


# =========================
# Gemini (chỉ backend/rag đọc GEMINI_* — Node proxy qua RAG, không gọi Gemini SDK)
# =========================
GEMINI_API_KEY=PASTE_YOUR_REAL_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=45


# =========================
# RAG service (backend/rag) — optional hardening
# =========================
# RAG_ENV=development
# RAG_LOG_LEVEL=INFO
# RAG_DEBUG=false
# RAG_LOG_JSON=false
# RAG_READY_REQUIRES_INDEX=true
# RAG_ENABLE_METRICS=false
# RAG_GEMINI_EXECUTOR_WORKERS=4

# Phase 7 — Node v2 place tables (disable legacy destinations fallback in place-id map)
# USE_V2_PLACE_TABLES=false
# PLACE_ID_LEGACY_FALLBACK=true
# Bật khóa nội bộ: FastAPI yêu cầu X-RAG-Internal-Key hoặc Bearer; backend Node tự gắn header khi gọi RAG (đặt cùng giá trị ở đây và trong .env cho Node).
# RAG_INTERNAL_API_KEY=
# Khóa riêng cho /admin/* (khuyến nghị prod). Nếu không đặt, /admin/* vẫn dùng RAG_INTERNAL_API_KEY.
# RAG_ADMIN_API_KEY=
# ADMIN_BASIC_USER=
# ADMIN_BASIC_PASS=
# Comma-separated browser origins for CORSMiddleware (leave empty for server-to-server only)
# RAG_CORS_ORIGINS=http://localhost:3000
# Giới hạn số request /rag/* và /ai/* mỗi IP mỗi phút (0 = tắt). Có REDIS_URL: dùng Redis (nhiều replica); không: in-memory mỗi process.
# RAG_RATE_LIMIT_PER_MINUTE=120
# RRF fusion BM25 + TF-IDF (cần build index mới bằng scripts/06_build_bm25_index.py)
# RAG_ENABLE_RRF=true
# Circuit breaker Gemini sau nhiều lỗi quota liên tiếp
# RAG_GEMINI_CIRCUIT_FAILURES=4
# RAG_GEMINI_CIRCUIT_COOLDOWN_SECONDS=90
# OpenTelemetry (cài thêm: opentelemetry-instrumentation-fastapi opentelemetry-exporter-otlp)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Redis (tùy chọn — rate limit + cache Gemini). Với `docker compose up` ở gốc repo Redis đã được bật trong stack.
# Riêng Redis: `docker compose -f deploy/redis-compose.yml up -d`
# REDIS_URL=redis://127.0.0.1:6379/0
# Tiền tố key (mặc định unutrip:rag:)
# REDIS_KEY_PREFIX=unutrip:rag:
# TTL cache câu trả Gemini (giây, mặc định 86400)
# GEMINI_CACHE_TTL_SECONDS=86400


# =========================
# Android (same repo root: local.properties — gitignored)
# Copy keys here manually; do not commit local.properties.
# GEMINI_API_KEY=...
# API_BASE_URL=http://10.0.2.2:3000/api/

# =========================
# Docker Compose (file `docker-compose.yml` ở gốc repo)
# Chuẩn bị: copy file này thành `.env` rồi chỉnh secrets. Compose dùng `.env` trong `env_file` của backend/rag.
# Các biến DB_HOST / RAG_BASE_URL / REDIS_URL cho MySQL & RAG trong compose đã được override phù hợp mạng Docker.
# =========================
# MYSQL_ROOT_PASSWORD=unutrip_root_secret
# MYSQL_USER=unutrip
# MYSQL_PASSWORD=unutrip_pass
# MYSQL_PUBLISH_PORT=3306
# BACKEND_PUBLISH_PORT=3000
# RAG_PUBLISH_PORT=8001
