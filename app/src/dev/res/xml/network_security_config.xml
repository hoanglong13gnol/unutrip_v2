<?xml version="1.0" encoding="utf-8"?>
<!-- Dev: HTTP emulator (10.0.2.2) / LAN — networkSecurityConfig ghi đè usesCleartext nên phải bật cleartext ở đây. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
