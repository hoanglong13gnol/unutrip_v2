<?xml version="1.0" encoding="utf-8"?>
<!-- Prod / mặc định: không cleartext; flavor dev bật usesCleartextTraffic để gọi HTTP local. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
