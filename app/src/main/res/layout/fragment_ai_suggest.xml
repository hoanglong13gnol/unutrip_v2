<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ai_suggest_header"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="56dp"
            android:paddingBottom="36dp">

            <!-- Back button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back_white"
                android:background="@drawable/bg_icon_circle_white"
                android:padding="10dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="28sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Gợi ý Lịch trình"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-rounded" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Powered by Google Gemini"
                        android:textColor="@color/white_60"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Form card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Date range -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Thời gian chuyến đi"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutStartDate"
                        style="@style/TextInput.Rounded"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Ngày đi"
                        app:endIconDrawable="@drawable/ic_calendar"
                        app:endIconMode="custom">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="→"
                        android:textColor="@color/text_hint"
                        android:layout_gravity="center_vertical" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEndDate"
                        style="@style/TextInput.Rounded"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Ngày về"
                        app:endIconDrawable="@drawable/ic_calendar"
                        app:endIconMode="custom">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Budget -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Ngân sách (VNĐ)"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="20dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutBudget"
                    style="@style/TextInput.Rounded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="VD: 5000000"
                    app:startIconDrawable="@drawable/ic_money">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBudget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Start location -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Xuất phát từ"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="20dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutStartLocation"
                    style="@style/TextInput.Rounded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Thành phố xuất phát"
                    app:startIconDrawable="@drawable/ic_location_pin">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStartLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:hint="VD: Hà Nội, TP.HCM..." />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Preferences -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Sở thích du lịch"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="20dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPrefs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:singleLine="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefBeach"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🏖️ Biển" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefMountain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="⛰️ Núi" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🏙️ Thành phố" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefHeritage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🏛️ Di tích" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefNature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🌿 Thiên nhiên" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefFood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🍜 Ẩm thực" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefCheckin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="📸 Check-in" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefCulture"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🏺 Văn hóa" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefShopping"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="🛍️ Mua sắm" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrefRelax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/Chip.Category"
                        android:text="💆 Nghỉ dưỡng" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Generate button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnGenerate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="56dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_ai_button"
                    android:text="✨ Tạo lịch trình với AI"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Loading state -->
        <LinearLayout
            android:id="@+id/layoutLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminateTint="@color/accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI đang tạo lịch trình…"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini đang phân tích sở thích của bạn"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
