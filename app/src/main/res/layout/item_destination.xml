<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="280dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/surface">

    <!-- Destination Image -->
    <ImageView
        android:id="@+id/ivDestination"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/placeholder_destination" />

    <!-- Gradient overlay from bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_card_overlay" />

    <!-- Favorite button - top right -->
    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_gravity="top|end"
        android:layout_margin="14dp"
        android:src="@drawable/ic_favorite_outline"
        android:background="@drawable/bg_white_circle"
        android:backgroundTint="@color/white_90"
        android:padding="9dp"
        app:tint="@color/accent" />
    <ImageView
        android:id="@+id/ivMap"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="58dp"
        android:layout_marginEnd="14dp"
        android:src="@drawable/ic_map"
        android:background="@drawable/bg_white_circle"
        android:backgroundTint="@color/white_90"
        android:padding="9dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        app:tint="@color/primary" />

    <!-- Category badge - top left -->
    <TextView
        android:id="@+id/tvCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="14dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:background="@drawable/bg_category_badge"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:text="🏖️ Biển" />

    <!-- Bottom info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Destination Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên địa điểm"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:letterSpacing="-0.01" />

        <!-- City row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_location_pin"
                app:tint="@color/white_70" />

            <TextView
                android:id="@+id/tvCity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thành phố"
                android:textColor="@color/white_70"
                android:textSize="12sp"
                android:paddingStart="4dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Rating badge -->
            <LinearLayout
                android:id="@+id/layoutRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rating_pill"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp">

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.8"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/ic_star"
                    app:tint="@color/star_color" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fee row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvReviewCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(128 reviews)"
                android:textColor="@color/white_50"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="1.2 km"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tvFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Miễn phí"
                android:textColor="@color/fee_on_image"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
