<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_rounded"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="40dp">

            <!-- Top row: greeting + avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xin chào, [Tên]"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:letterSpacing="0.05"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hôm nay đi đâu? 🌎"
                        android:textColor="@color/text_primary"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-rounded"
                        android:layout_marginTop="4dp"
                        android:letterSpacing="-0.02" />
                </LinearLayout>

                <!-- Notification bell -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivNotification"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/unu_logo"
                        android:background="@drawable/bg_icon_circle_white"
                        android:backgroundTint="@color/white_10"
                        android:padding="11dp"
                        />
                    <!-- Dot badge if needed -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_accent_circle"
                        android:backgroundTint="@color/accent" />
                </FrameLayout>
            </LinearLayout>

            <!-- Search Bar -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:id="@+id/searchView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tìm tên địa điểm, thành phố..."
                        android:textColor="@color/text_hint"
                        android:textSize="15sp"
                        android:paddingStart="14dp" />

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/ic_filter"
                        android:background="@drawable/bg_accent_circle"
                        android:padding="9dp"
                        app:tint="@color/white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ===== CATEGORY CHIPS ===== -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="🗺️ Tất cả"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBeach"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_beach" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMountain"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_mountain" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCity"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_city" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHeritage"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_heritage" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNature"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_nature" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCheckin"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_checkin" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHistorical"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_historical" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFood"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_food" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCulture"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_culture" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipReligious"
                    style="@style/Chip.Category"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/cat_religious" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ===== FEATURED SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Địa điểm nổi bật 🔥"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/btnViewAllFeatured"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả →"
                android:textSize="13sp"
                android:textColor="@color/accent" />
        </LinearLayout>

        <!-- Featured Progress -->
        <ProgressBar
            android:id="@+id/progressFeatured"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:indeterminateTint="@color/accent" />

        <!-- Featured RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFeatured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- ===== NEARBY SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gần bạn 📍"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/btnViewAllNearby"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem tất cả →"
                android:textSize="13sp"
                android:textColor="@color/accent" />
        </LinearLayout>

        <!-- Nearby Progress -->
        <ProgressBar
            android:id="@+id/progressNearby"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:indeterminateTint="@color/accent" />

        <!-- Nearby RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNearby"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="8dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:orientation="horizontal"
            android:paddingBottom="24dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
