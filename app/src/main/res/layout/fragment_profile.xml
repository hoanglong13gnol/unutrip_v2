<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header with avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="64dp"
            android:paddingBottom="48dp">

            <!-- Avatar -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivAvatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_default_avatar"
                app:civ_border_width="3dp"
                app:civ_border_color="@color/white_15" />

            <!-- Edit overlay -->
            <ImageView
                android:id="@+id/btnEditAvatar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginTop="-30dp"
                android:layout_marginStart="64dp"
                android:src="@drawable/ic_camera"
                android:background="@drawable/bg_accent_circle"
                android:padding="7dp"
                app:tint="@color/white" />

            <!-- Name -->
            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Người dùng UNUtrip"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-rounded"
                android:layout_marginTop="16dp"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="traveler@unutrip.local"
                android:textColor="@color/white_70"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_stats_card"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvItineraryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch trình"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white_70"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="@color/white_10" />

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvFavoriteCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yêu thích"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white_70"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="@color/white_10" />

                <LinearLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvReviewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="@color/white_70"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Menu items -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Edit Profile -->
                <include layout="@layout/item_profile_menu"
                    android:id="@+id/menuEditProfile" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="52dp"
                    android:alpha="0.5" />

                <!-- My Favorites -->
                <include layout="@layout/item_profile_menu"
                    android:id="@+id/menuFavorites" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="52dp"
                    android:alpha="0.5" />

                <!-- My Itineraries -->
                <include layout="@layout/item_profile_menu"
                    android:id="@+id/menuItineraries" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="52dp"
                    android:alpha="0.5" />

                <!-- Settings -->
                <include layout="@layout/item_profile_menu"
                    android:id="@+id/menuSettings" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="40dp"
            android:text="Đăng xuất"
            android:textColor="@color/accent_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/white"
            app:cornerRadius="16dp"
            app:strokeColor="@color/accent_light"
            app:strokeWidth="1dp"
            app:rippleColor="@color/accent_light" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
