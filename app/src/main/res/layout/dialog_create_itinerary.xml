<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_rounded">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="📅 Tạo lịch trình mới" android:textSize="20sp" android:textStyle="bold" android:fontFamily="sans-serif-rounded"
        android:textColor="@color/text_primary" android:layout_marginBottom="16dp" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/TextInput.Rounded"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:hint="Tên lịch trình *">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTitle" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/TextInput.Rounded"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:hint="Mô tả (tùy chọn)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDescription" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="textMultiLine" android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <com.google.android.material.textfield.TextInputLayout
            style="@style/TextInput.Rounded"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Ngày đi *"
            app:endIconDrawable="@drawable/ic_calendar" app:endIconMode="custom">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etStartDate" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:focusable="false" android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="8dp" android:layout_height="1dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/TextInput.Rounded"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Ngày về *"
            app:endIconDrawable="@drawable/ic_calendar" app:endIconMode="custom">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEndDate" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:focusable="false" android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="20dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hủy" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreate"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Tạo lịch trình" />
    </LinearLayout>
</LinearLayout>
