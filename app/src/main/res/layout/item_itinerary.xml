<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Modern side accent -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/accent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên lịch trình"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-rounded"
                        android:textColor="@color/text_primary"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:letterSpacing="-0.01" />

                    <!-- AI badge -->
                    <TextView
                        android:id="@+id/tvAIBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨ THÔNG MINH AI"
                        android:textSize="9sp"
                        android:textColor="@color/accent_dark"
                        android:textStyle="bold"
                        android:background="@drawable/bg_ai_badge"
                        android:backgroundTint="@color/accent"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginTop="6dp"
                        android:visibility="gone"
                        android:textAllCaps="true" />
                </LinearLayout>

                <!-- More options -->
                <ImageView
                    android:id="@+id/btnMore"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_more_vertical"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/text_hint" />
            </LinearLayout>

            <!-- Date & Duration row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <!-- Calendar -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/primary" />

                    <TextView
                        android:id="@+id/tvDates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12/03 - 15/03/2026"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:paddingStart="8dp" />
                </LinearLayout>

                <!-- Duration -->
                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 ngày"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:background="@drawable/bg_duration_pill"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

            <!-- Budget row -->
            <LinearLayout
                android:id="@+id/layoutBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_money"
                    app:tint="@color/success" />

                <TextView
                    android:id="@+id/tvBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngân sách: 5.000.000đ"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:paddingStart="8dp" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã lên kế hoạch"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:background="@drawable/bg_status_pill"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
