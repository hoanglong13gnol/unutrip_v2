<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header_rounded"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- AI Avatar -->
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/unu_logo"
            android:background="@drawable/bg_ai_avatar"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trợ lý Mèo Du Lịch"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-rounded" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_online_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Powered by Gnol"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingStart="5dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Clear chat -->
        <ImageView
            android:id="@+id/btnClearChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_refresh"
            android:background="@drawable/bg_icon_circle_white"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Quick suggestion chips -->
    <HorizontalScrollView
        android:id="@+id/scrollSuggestions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:scrollbars="none"
        android:background="@color/background"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggest1"
                style="@style/Chip.Category"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📍 Gợi ý Đà Nẵng"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggest2"
                style="@style/Chip.Category"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="🗓️ Lịch trình Hội An"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuggest3"
                style="@style/Chip.Category"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="🍜 Ẩm thực Hà Nội"
                android:textSize="12sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Messages List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/scrollSuggestions"
        app:layout_constraintBottom_toTopOf="@id/layoutTyping"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/layoutTyping"
        android:layout_width="0dp"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/inputArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressTyping"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminateTint="@color/accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trợ lý đang soạn tin…"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:paddingStart="8dp" />

    </LinearLayout>

    <!-- Input area -->
    <LinearLayout
        android:id="@+id/inputArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/TextInput.Rounded"
            android:hint="@string/chat_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:gravity="center_vertical|start"
                android:inputType="text|textCapSentences|textAutoCorrect"
                android:imeOptions="actionSend|flagNoExtractUi"
                android:singleLine="true"
                android:maxLines="1"
                android:importantForAutofill="no"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Send button -->
        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_send_button"
            android:padding="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
