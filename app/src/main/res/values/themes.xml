<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SmartTravel" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/text_on_accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="fontFamily">sans-serif-rounded</item>
        <item name="materialButtonStyle">@style/Button.Primary</item>
        <item name="chipStyle">@style/Chip.Category</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>
    </style>

    <style name="Theme.SmartTravel.NoActionBar" parent="Theme.SmartTravel">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="CardStyle.Destination" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="CardStyle.Chat" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="rippleColor">@color/accent_light</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="cornerRadius">22dp</item>
        <item name="elevation">0dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="rippleColor">@color/accent_light</item>
        <item name="android:textColor">@color/accent_dark</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="cornerRadius">22dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextInput.Rounded" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="boxStrokeColor">@color/text_input_stroke_selector</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="startIconTint">@color/text_secondary</item>
        <item name="endIconTint">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
    </style>

    <style name="Text.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">27sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="Text.H1" parent="Text.Display">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
    </style>

    <style name="Text.H2" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
    </style>

    <style name="Text.H3" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
    </style>

    <style name="Text.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
    </style>

    <style name="Text.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
    </style>

    <style name="BottomSheetSmartTravel" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="Chip.Category" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">18dp</item>
        <item name="chipMinHeight">38dp</item>
        <item name="chipBackgroundColor">@color/chip_bg_selector</item>
        <item name="chipStrokeColor">@color/chip_stroke_selector</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconEnabled">false</item>
        <item name="rippleColor">@color/accent_light</item>
        <item name="android:textColor">@color/chip_text_selector</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
    </style>

</resources>
